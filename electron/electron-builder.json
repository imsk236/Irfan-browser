{
  "appId": "com.irfan.manuscript-archive",
  "productName": "أرشيف عرفان للمخطوطات",
  "electronVersion": "34.5.8",
  "directories": {
    "buildResources": "resources",
    "output": "out"
  },
  "files": [
    "dist/**",
    "resources/**",
    "!node_modules/**"
  ],
  "extraResources": [
    {
      "from": "resources/backend",
      "to": "backend"
    },
    {
      "from": "resources/archive.db",
      "to": "archive.db"
    },
    {
      "from": "../frontend/dist",
      "to": "frontend/dist"
    },
    {
      "from": "resources/icon.ico",
      "to": "icon.ico"
    }
  ],
  "artifactName": "irfan-archive-setup-${version}.${ext}",
  "win": {
    "target": "nsis",
    "icon": "resources/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "language": "1025"
  },
  "publish": {
    "provider": "github",
    "owner": "imsk236",
    "repo": "Irfan-browser",
    "releaseType": "release"
  }
}
