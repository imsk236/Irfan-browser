{
  "appId": "com.irfan.manuscript-archive",
  "productName": "أرشيف عرفان للمخطوطات",
  "electronVersion": "34.5.8",
  "directories": {
    "buildResources": "resources",
    "output": "out"
  },
  "files": [
    "dist/**",
    "resources/**",
    "!node_modules/**"
  ],
  "extraResources": [
    {
      "from": "resources/backend",
      "to": "backend"
    },
    {
      "from": "resources/archive.db",
      "to": "archive.db"
    },
    {
      "from": "../frontend/dist",
      "to": "frontend/dist"
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "resources/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "installerLanguages": ["ar"]
  }
}
